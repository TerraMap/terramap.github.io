    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^17.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^6.4.2",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@panzoom/panzoom": "^4.6.2",
    "antd": "^6.4.3",
