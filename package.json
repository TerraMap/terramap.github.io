    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "vitest": "vitest run",
    "vitest:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
